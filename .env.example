# ===========================================
# Suburb Intel - Environment Variables
# ===========================================

# Database (Supabase PostgreSQL)
# Get from: Supabase Dashboard → Settings → Database → Connection string (ORM tab)
DATABASE_URL="postgresql://postgres.YOUR_PROJECT:YOUR_PASSWORD@aws-1-ap-southeast-2.pooler.supabase.com:6543/postgres?pgbouncer=true"
DIRECT_URL="postgresql://postgres.YOUR_PROJECT:YOUR_PASSWORD@aws-1-ap-southeast-2.pooler.supabase.com:5432/postgres"

# Application
NEXT_PUBLIC_APP_URL=https://your-domain.vercel.app
NODE_ENV=production

# Analytics (Google Analytics)
NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX

# Email (Resend - for alerts/notifications, optional)
RESEND_API_KEY=re_xxxxxxxxxxxx
EMAIL_FROM=noreply@suburbintel.com.au

# Admin Access (comma-separated emails)
ADMIN_EMAILS=your-email@example.com

# Cron Job Security (generate with: openssl rand -base64 32)
CRON_SECRET_KEY=your-cron-secret
